// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
  VISITOR
  BLOCKED
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole        @default(VISITOR)
  accounts      Account[]
  sessions      Session[]
  // Optional for WebAuthn support
  Authenticator Authenticator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects       UserProject[]
  activities     UserActivity[]
  createdActivities Activity[]
}

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  logoUrl       String?
  coverUrl      String?
  backgroundUrl String?
  logoHorizontalUrl String?
  link          String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users      UserProject[]
  activities Activity[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model UserProject {
  userId    String
  projectId String
  role      String? // e.g., 'manager', 'member'
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
}

model MobileAuthSession {
  id        String   @id @default(cuid())
  sessionId String   @unique
  token     String?
  userData  String?
  error     String?
  expires   DateTime
  createdAt DateTime @default(now())
}

// Optional for WebAuthn support
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

enum UserActivityRole {
  OWNER
  ORGANIZER
  PARTICIPANT
  GUEST
  PENDING
  BLOCKED
  INVITED
}

enum ActivityType {
  EVENT
  TASK
}

model Activity {
  id            String   @id @default(cuid())
  name          String
  description   String?
  type          ActivityType @default(EVENT)
  dataInicio    DateTime
  dataFim       DateTime?
  hideEndData   Boolean  @default(false)
  projectId     String
  createdBy     String
  publishedAt   DateTime?
  visible       Boolean  @default(true)
  logoUrl       String?
  coverUrl      String?
  backgroundUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator   User    @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  users     UserActivity[]
}

model UserActivity {
  userId     String
  activityId String
  role       UserActivityRole @default(PARTICIPANT)
  accessCode String?          @unique
  isFavorite Boolean          @default(false)
  checkedInAt DateTime?
  lastMuralView DateTime?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([userId, activityId])
}
